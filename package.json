{
  "name": "twitter-indexer",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "mcp": "tsx src/mcp/server.ts",
    "mcp:stdio": "MCP_MODE=stdio tsx src/mcp/server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.39.0",
    "fastify": "^5.2.0",
    "grammy": "^1.35.0",
    "js-yaml": "^4.1.0",
    "node-cron": "^3.0.3",
    "otpauth": "^9.4.0",
    "pg": "^8.13.0",
    "playwright": "^1.58.2",
    "set-cookie-parser": "^2.7.0",
    "tough-cookie": "^5.1.0",
    "undici": "^7.24.6",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.0",
    "@types/set-cookie-parser": "^2.4.7",
    "@types/tough-cookie": "^4.0.5",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
